{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/execute.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/manage-trades.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/broker.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/news-context.js": {
      "memory": 512,
      "maxDuration": 15
    },
    "api/sizing-engine.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/symbol-resolver.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/diag.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/alexg-run.js": {
      "memory": 1024,
      "maxDuration": 180
    },
    "api/alexg-trade.js": {
      "memory": 1024,
      "maxDuration": 180
    },
    "api/alexg-heartbeat.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/alexg-watchdog.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/manage-trades",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/alexg-run",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/alexg-watchdog",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin",      "value": "*" },
        { "key": "Access-Control-Allow-Methods",     "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers",     "value": "Content-Type, Authorization" }
      ]
    }
  ]
}