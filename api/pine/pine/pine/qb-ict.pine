orbMaxWidthATR= input.float(5.0, "Width filter MAX (× M15 ATR)", minval=1.0, step=0.5, group=G_ORB, tooltip="Skip sessions whose opening range is too WIDE (chop). Range ÷ ATR above this = no trade. The single biggest defense against ORB overfitting.")

// ─── COLOR CONSTANTS ─────────────────────────────────────────────────

color C_BULL    = #14B8A6
color C_BEAR    = #F43F5E
color C_NEUT    = #94A3B8
color C_AMBER   = #F59E0B
color C_GOLD    = #EAB308
