showPhaseBox     = input.bool(true,  "AMD phase box",          group=G_VIS)
showTradeSignal  = input.bool(true,  "Trade signal label",     group=G_VIS)
showPDHPDL       = input.bool(true,  "PDH / PDL lines",        group=G_VIS)
showStatusBadge  = input.bool(true,  "Status badge top-right", group=G_VIS)
showPriceLabels  = input.bool(true,  "Prices on level labels", group=G_VIS)
phaseTintBg      = input.bool(false, "Subtle phase background tint", group=G_VIS)
showPosBox       = input.bool(true,  "Position box (entry / SL / TP3)", group=G_VIS, tooltip="Draws the trade box on every fired signal: green zone entry→TP3, red zone entry→SL, dashed entry line. Pure visual — does not affect any trade logic.")
posBoxBars       = input.int(40, "Position box width (bars)", minval=5, maxval=300, group=G_VIS)

